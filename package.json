{
  "name": "agent-core",
  "version": "0.1.0",
  "description": "A TypeScript agent loop core with OpenAI-compatible tool calling.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "agent-core-repl": "./dist/repl.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "repl": "tsx src/repl.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
